{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "appName": {
      "type": "string",
      "defaultValue": "integrid-workbook",
      "metadata": {
        "description": "Base name for all resources. Lowercase letters and hyphens only."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "allowedValues": [
        "eastus2",
        "eastus",
        "centralus",
        "westus2",
        "westeurope",
        "uksouth"
      ],
      "metadata": {
        "description": "Azure region. Must support Azure Static Web Apps."
      }
    },
    "githubRepoUrl": {
      "type": "string",
      "defaultValue": "https://github.com/integrid-int/SalesDash",
      "metadata": {
        "description": "GitHub repository URL (https://github.com/org/repo)."
      }
    },
    "githubBranch": {
      "type": "string",
      "defaultValue": "main"
    },
    "githubToken": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "GitHub Personal Access Token with repo scope. Required to link the SWA to GitHub."
      }
    }
  },
  "variables": {
    "storageAccountName": "[toLower(concat(replace(take(parameters('appName'),14),'-',''),'stor'))]",
    "staticWebAppName": "[concat(parameters('appName'),'-swa')]"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-01-01",
      "name": "[variables('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "Standard_LRS" },
      "kind": "StorageV2",
      "properties": {
        "supportsHttpsTrafficOnly": true,
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false
      },
      "tags": { "app": "[parameters('appName')]" }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/tableServices/tables",
      "apiVersion": "2023-01-01",
      "name": "[concat(variables('storageAccountName'),'/default/workbookEntries')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/tableServices/tables",
      "apiVersion": "2023-01-01",
      "name": "[concat(variables('storageAccountName'),'/default/workbookMeta')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/staticSites",
      "apiVersion": "2023-01-01",
      "name": "[variables('staticWebAppName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "Free", "tier": "Free" },
      "properties": {
        "repositoryUrl": "[parameters('githubRepoUrl')]",
        "branch": "[parameters('githubBranch')]",
        "repositoryToken": "[parameters('githubToken')]",
        "buildProperties": {
          "appLocation": "public",
          "apiLocation": "api",
          "outputLocation": ""
        }
      },
      "tags": { "app": "[parameters('appName')]" }
    },
    {
      "type": "Microsoft.Web/staticSites/config",
      "apiVersion": "2023-01-01",
      "name": "[concat(variables('staticWebAppName'),'/appsettings')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/staticSites', variables('staticWebAppName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ],
      "properties": {
        "STORAGE_CONNECTION_STRING": "[concat('DefaultEndpointsProtocol=https;AccountName=',variables('storageAccountName'),';AccountKey=',listKeys(resourceId('Microsoft.Storage/storageAccounts',variables('storageAccountName')),'2023-01-01').keys[0].value,';EndpointSuffix=core.windows.net')]"
      }
    }
  ],
  "outputs": {
    "swaUrl": {
      "type": "string",
      "value": "[concat('https://',reference(resourceId('Microsoft.Web/staticSites',variables('staticWebAppName'))).defaultHostname)]"
    },
    "swaName": {
      "type": "string",
      "value": "[variables('staticWebAppName')]"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[variables('storageAccountName')]"
    },
    "nextStep": {
      "type": "string",
      "value": "[concat('Run: pwsh deploy/Deploy-All.ps1 -ResourceGroup ',resourceGroup().name,' -SwaName ',variables('staticWebAppName'),' -SetGithubSecret')]"
    }
  }
}
