{
  "routes": [
    {
      "route": "/.auth/logout",
      "redirect": "/",
      "statusCode": 302
    },
    {
      "route": "/api/ping",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "globalHeaders": {
    "Cache-Control": "no-store",
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN"
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/*.html", "/*.js", "/*.css", "/*.json"]
  },
  "platform": {
    "apiRuntime": "node:20"
  }
}
